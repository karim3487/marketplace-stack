# PostgreSQL Settings
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=marketplace

# Backend Database URL (For Local Development)
# Docker переопределит этот URL внутри себя через docker-compose.yaml
DATABASE_URL=postgresql+asyncpg://admin:changeme@localhost:5432/marketplace

# MinIO Settings (Internal Root)
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=changeme

# S3/MinIO Backend Configuration
MINIO_ENDPOINT=http://localhost:9000
MINIO_BROWSER_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET_NAME=products
MINIO_PUBLIC_URL=http://localhost:9000/products

# App Ports
BACKEND_PORT=8000
FRONTEND_PORT=5173
